{
  "name": "codingplan-status-vscode",
  "displayName": "CodingPlan Status",
  "description": "在 VS Code 状态栏显示 Coding Plan 额度与用量，支持 MiniMax、Infini AI 等多供应商",
  "version": "1.0.0",
  "publisher": "JochenYang",
  "icon": "./public/icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codingplanStatus.setup",
        "title": "CodingPlan Status: 配置向导",
        "category": "CodingPlan",
        "description": "配置 Coding Plan 供应商凭据"
      },
      {
        "command": "codingplanStatus.refresh",
        "title": "CodingPlan Status: 刷新状态",
        "category": "CodingPlan",
        "description": "手动刷新额度状态"
      },
      {
        "command": "codingplanStatus.switchProvider",
        "title": "CodingPlan Status: 切换供应商",
        "category": "CodingPlan",
        "description": "切换当前使用的供应商"
      },
      {
        "command": "codingplanStatus.showInfo",
        "title": "CodingPlan Status: 显示详情",
        "category": "CodingPlan",
        "description": "显示当前额度与用量详情"
      },
      {
        "command": "codingplanStatus.showHelp",
        "title": "CodingPlan Status: 打开帮助",
        "category": "CodingPlan",
        "description": "查看使用教程"
      },
      {
        "command": "codingplanStatus.showLogs",
        "title": "CodingPlan Status: 查看日志",
        "category": "CodingPlan",
        "description": "打开扩展日志输出"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codingplanStatusSidebar",
          "title": "CodingPlan Status",
          "icon": "public/icon.png"
        }
      ]
    },
    "views": {
      "codingplanStatusSidebar": [
        {
          "id": "codingplanStatusView",
          "name": "设置"
        }
      ]
    },
    "configuration": {
      "title": "CodingPlan Status",
      "properties": {
        "codingplanStatus.showTooltip": {
          "type": "boolean",
          "default": true,
          "description": "显示详细提示信息",
          "order": 1
        },
        "codingplanStatus.language": {
          "type": "string",
          "enum": [
            "zh-CN",
            "en-US"
          ],
          "default": "zh-CN",
          "description": "Language / 语言",
          "order": 2
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild ./extension.js --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild ./extension.js --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js",
    "package": "npm run build && vsce package",
    "install-test": "npm install"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "esbuild": "^0.25.2",
    "eslint": "^8.56.0",
    "mocha": "^10.8.2",
    "@vscode/vsce": "^2.21.0"
  },
  "dependencies": {
    "axios": "^1.6.2"
  },
  "keywords": [
    "codingplan",
    "minimax",
    "infini",
    "status",
    "claude"
  ],
  "author": "Jochen Yang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vncntvx/codingplan-status"
  }
}

{
  "name": "codingplan-status-vscode",
  "displayName": "CodingPlan Status",
  "description": "在 VS Code 状态栏显示 Coding Plan 额度与用量，支持 MiniMax、Infini AI 等多供应商",
  "version": "1.0.0",
  "publisher": "JochenYang",
  "icon": "./public/icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:codingplanStatusView"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codingplanStatus.setup",
        "title": "CodingPlan Status: 配置向导",
        "category": "CodingPlan",
        "description": "配置 Coding Plan 供应商凭据"
      },
      {
        "command": "codingplanStatus.refresh",
        "title": "CodingPlan Status: 刷新状态",
        "category": "CodingPlan",
        "description": "手动刷新额度状态"
      },
      {
        "command": "codingplanStatus.switchProvider",
        "title": "CodingPlan Status: 切换供应商",
        "category": "CodingPlan",
        "description": "切换当前使用的供应商"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codingplanStatusSidebar",
          "title": "CodingPlan Status",
          "icon": "public/icon.png"
        }
      ]
    },
    "views": {
      "codingplanStatusSidebar": [
        {
          "id": "codingplanStatusView",
          "name": "设置"
        }
      ]
    },
    "configuration": {
      "title": "CodingPlan Status",
      "properties": {
        "codingplanStatus.refreshInterval": {
          "type": "number",
          "default": 30,
          "description": "刷新间隔（秒）",
          "order": 1
        },
        "codingplanStatus.showTooltip": {
          "type": "boolean",
          "default": true,
          "description": "显示详细提示信息",
          "order": 2
        },
        "codingplanStatus.language": {
          "type": "string",
          "enum": ["zh-CN", "en-US"],
          "default": "zh-CN",
          "description": "Language / 语言",
          "order": 3
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js",
    "package": "vsce package",
    "install-test": "npm install"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "eslint": "^8.56.0",
    "@vscode/vsce": "^2.21.0"
  },
  "dependencies": {
    "axios": "^1.6.2"
  },
  "keywords": [
    "codingplan",
    "minimax",
    "infini",
    "status",
    "claude"
  ],
  "author": "Jochen Yang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vncntvx/codingplan-status"
  }
}
